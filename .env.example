# ──────────────────────────────────────────────────────────────
# pol_lp environment configuration (copy to .env and fill in)
# ─────────────────────────────────────────────────────────────

# Mode: paper (default, safe) or live
TRADING_MODE=paper

# ── Wallet / auth ──────────────────────────────────────────────
# Private key of the EOA that signs L1 auth + orders (NEVER commit the real .env)
PRIVATE_KEY=
# Polymarket signature type: 0=EOA, 1=POLY_PROXY, 2=GNOSIS_SAFE, 3=POLY_1271 (deposit wallet, new API users)
SIGNATURE_TYPE=3
# Funder / deposit wallet address (the maker for signature type 3)
FUNDER_ADDRESS=

# ── CLOB L2 API credentials (auto-derived from PRIVATE_KEY if left blank) ──
CLOB_API_KEY=
CLOB_API_SECRET=
CLOB_API_PASSPHRASE=

# ── Endpoints (defaults are correct for mainnet) ──────────────
CLOB_HTTP_URL=https://clob.polymarket.com
CLOB_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
GAMMA_URL=https://gamma-api.polymarket.com
CHAIN_ID=137

# ── Capital / sizing ───────────────────────────────────────
STARTING_BALANCE=100
MAX_SINGLE_MARKET_USD=40
DEFAULT_SHARES_PER_SIDE=75
# Hard cap on any single live order's notional (USDC). Start tiny.
LIVE_MAX_ORDER_USD=10

# ── WebSocket tuning ────────────────────────────────────────────
WS_PARALLEL_CONNECTIONS=3
WS_PRUNE_INTERVAL_SEC=30
WS_MAX_PRICE_JUMP=0.15
WS_MIN_WARMUP_TICKS=3

# ── Logging ────────────────────────────────────────────────────
LOG_LEVEL=info
DEBUG_REJECTED_TICKS=false
