# ────────────────────────────────────────────────────────
# pol_lp environment configuration (copy to .env and fill in)
# Polymarket CLOB V2 (April 2026 cutover). Collateral = pUSD (not USDC.e).
# ──────────────────────────────────────────────────

# Mode: paper (default, safe) or live
TRADING_MODE=paper

# ── Wallet / auth ────────────────────────────────────────
PRIVATE_KEY=
SIGNATURE_TYPE=3
FUNDER_ADDRESS=

# ── CLOB L2 API credentials (auto-derived from PRIVATE_KEY if left blank) ──
CLOB_API_KEY=
CLOB_API_SECRET=
CLOB_API_PASSPHRASE=

# ── Endpoints (defaults are correct for mainnet) ──────────────
CLOB_HTTP_URL=https://clob.polymarket.com
CLOB_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
GAMMA_URL=https://gamma-api.polymarket.com
CHAIN_ID=137
RPC_URL=https://polygon-rpc.com

# ── Discovery ─────────────────────────────────────
# Broad scan. The bot joins Gamma active markets with CLOB reward/sampling endpoints
# and only farms funded rewards (CLOB rewards.rates daily rate > 0) when available.
DISCOVERY_GAMMA_LIMIT=500
CLOB_REWARD_SCAN_PAGES=30

# ── Capital / sizing ──────────────────────────────
STARTING_BALANCE=100
MAX_SINGLE_MARKET_USD=40
DEFAULT_SHARES_PER_SIDE=75
LIVE_MAX_ORDER_USD=10

# ── WebSocket tuning ───────────────────────────────
WS_PARALLEL_CONNECTIONS=3
WS_PRUNE_INTERVAL_SEC=30
WS_MAX_PRICE_JUMP=0.15
WS_MIN_WARMUP_TICKS=3

# ── Runtime strategy/settings overrides (optional) ───────────
SELECTION_ACT_SCORE=7
SELECTION_MAX_MARKETS=3
SIZING_SHARES_PER_SIDE=75
STRATEGY_ENABLE_CORE_MAKER=true
STRATEGY_ENABLE_GRID_LP=true
STRATEGY_ENABLE_STACKED_ARB=false
STRATEGY_ARB_MIN_EDGE=0.02
STRATEGY_ARB_SHARES_PER_SIDE=50
RISK_MAX_SINGLE_MARKET_USD=40
RISK_MAX_TOTAL_EXPOSURE_USD=90
ALERTS_ENABLED=true
ALERTS_MIN_INTERVAL_SEC=60

# ── Telegram control panel ─────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Auto-redeem resolved positions ──────────────────────
ENABLE_AUTO_REDEEM=false
GASLESS_REDEEM=false
RELAYER_URL=https://relayer-v2.polymarket.com
POLY_BUILDER_API_KEY=
POLY_BUILDER_API_SECRET=
POLY_BUILDER_API_PASSPHRASE=

# ── Logging ────────────────────────────────────
LOG_LEVEL=info
DEBUG_REJECTED_TICKS=false
